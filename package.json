{
  "name": "@sendly/node",
  "version": "0.1.1",
  "description": "Official Sendly Node.js SDK - Send SMS with ease",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "src/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "test": "jest",
    "test:unit": "jest test/unit --coverage",
    "test:integration": "jest test/integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src test --ext .ts",
    "format": "prettier --write src test --ext .ts",
    "type-check": "tsc --noEmit",
    "prepack": "npm run build && npm run test:unit",
    "prepublishOnly": "npm run lint && npm run type-check && npm run build && npm run test:unit",
    "publish:beta": "npm version prerelease --preid=beta && npm publish --tag beta",
    "publish:release": "npm publish"
  },
  "keywords": [
    "sms",
    "sendly",
    "messaging",
    "api",
    "typescript",
    "nodejs"
  ],
  "author": "Sendly Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sendly-live/sendly-node"
  },
  "bugs": {
    "url": "https://github.com/sendly-live/sendly-node/issues"
  },
  "homepage": "https://sendly.live",
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "@types/node": "^20.5.0",
    "@types/node-fetch": "^2.6.4",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "eslint": "^8.47.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.6.2",
    "prettier": "^3.0.2",
    "ts-jest": "^29.1.1",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
